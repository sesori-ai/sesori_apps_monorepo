# frozen_string_literal: true

default_platform(:ios)

# Returns the highest build number among the 25 most recently uploaded builds
# across all versions on App Store Connect (TestFlight + App Store).
#
# Why not Fastlane's `latest_testflight_build_number`? Without `version:`, that
# action queries `limit: 1, sort: -uploadedDate` and returns the MOST RECENT
# upload's build number — not the maximum. If a fresh marketing version was
# uploaded with build 2 after an older version's build 461, it returns 2.
# We need the numeric max, so we enumerate recent builds and reduce locally.
RECENT_BUILDS_LOOKBACK = 25

def highest_build_number_across_all_versions(api_key:)
  require "spaceship"

  Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
    key_id: api_key[:key_id],
    issuer_id: api_key[:issuer_id],
    key: api_key[:key]
  )

  app_identifier = CredentialsManager::AppfileConfig.try_fetch_value(:app_identifier)
  app = Spaceship::ConnectAPI::App.find(app_identifier)
  UI.user_error!("App not found on App Store Connect: #{app_identifier}") if app.nil?

  # Fetch the N most recently uploaded builds and compute the numeric max
  # client-side. ASC stores build numbers as strings, so server-side sort
  # is lexicographic and unusable. We only look at the recent window because
  # in practice the latest builds always hold the highest numbers.
  recent_builds = Spaceship::ConnectAPI::Build.all(
    app_id: app.id,
    sort: "-uploadedDate",
    limit: RECENT_BUILDS_LOOKBACK
  ).first(RECENT_BUILDS_LOOKBACK)

  highest = recent_builds.map { |b| b.version.to_i }.max || 0
  UI.message("Scanned #{recent_builds.size} most recent builds; highest build number: #{highest}")
  highest
end

platform :ios do
  # Reads the marketing version (e.g. "1.0.6") from pubspec.yaml two dirs up.
  # The build-number suffix after `+` is intentionally ignored — store APIs
  # own the build number, pubspec only owns the version name.
  private_lane :_read_marketing_version do
    pubspec_path = File.join(Dir.pwd, "..", "..", "pubspec.yaml")
    pubspec_content = File.read(pubspec_path)
    version_match = pubspec_content.match(/version:\s*(\d+\.\d+\.\d+)/)
    version_match ? version_match[1] : "1.0.0"
  end

  desc "Print the next TestFlight build number without building or uploading"
  lane :next_build_number do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: false
    )

    next_number = highest_build_number_across_all_versions(api_key: api_key) + 1

    # Stable marker line parsed by CI. Keep the `NEXT_BUILD_NUMBER=<n>` format.
    UI.message("NEXT_BUILD_NUMBER=#{next_number}")
    next_number
  end

  desc "Deploy a new build to TestFlight"
  lane :deploy_testflight do
    # Setup CI environment (creates temporary keychain)
    setup_ci if ENV["CI"]

    # Load App Store Connect API key
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: false
    )

    version = _read_marketing_version

    # Prefer a build number injected by the upstream "next build number" CI job
    # (cheap Linux runner). Fall back to querying ASC ourselves so standalone
    # invocations of this lane still work.
    injected = ENV["BUILD_NUMBER"].to_s.strip
    new_build_number = if injected.empty?
      highest_build_number_across_all_versions(api_key: api_key) + 1
    else
      UI.message("Using injected build number: #{injected}")
      Integer(injected)
    end

    UI.message("Building version #{version} (#{new_build_number})")

    # Update build number in Xcode project
    increment_build_number(
      build_number: new_build_number,
      xcodeproj: "Runner.xcodeproj"
    )

    # Update version number to match pubspec
    increment_version_number(
      version_number: version,
      xcodeproj: "Runner.xcodeproj"
    )

    # Sync code signing with Match
    match(
      type: "appstore",
      api_key: api_key,
      readonly: ENV["CI"] == "true"
    )

    app_identifier = CredentialsManager::AppfileConfig.try_fetch_value(:app_identifier)
    profile_name = ENV["sigh_#{app_identifier}_appstore_profile-name"]

    # Override automatic signing with match profile for CI
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Runner.xcodeproj",
      team_id: CredentialsManager::AppfileConfig.try_fetch_value(:team_id),
      bundle_identifier: app_identifier,
      profile_name: profile_name,
      code_sign_identity: "Apple Distribution"
    )

    # Build the app
    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          app_identifier => profile_name
        }
      },
      output_directory: "./build",
      output_name: "Runner.ipa"
    )

    # Upload to TestFlight. Embed the short commit SHA in the TestFlight
    # "What to Test" notes so it survives even if the matching `build-<N>`
    # git tag is ever lost — operators can recover the originating commit by
    # opening the build in App Store Connect.
    short_sha = ENV.fetch("GITHUB_SHA", `git rev-parse HEAD`.strip)[0, 7]
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      wait_for_uploaded_build: false,
      changelog: "Build #{new_build_number} (v#{version}) commit=#{short_sha}"
    )

    # Write build info for CI summary
    File.write("../build_info.env", "VERSION=#{version}\nBUILD_NUMBER=#{new_build_number}\n")

    UI.success("Successfully uploaded version #{version} (#{new_build_number}) to TestFlight!")
  end

  desc "Submit an existing TestFlight build for App Store review (production) " \
       "or external beta. Does NOT build — runs on Linux."
  lane :submit_ios do |options|
    build_number = (options[:build_number] || ENV["BUILD_NUMBER"]).to_s.strip
    UI.user_error!("BUILD_NUMBER is required") if build_number.empty?

    track = (options[:track] || ENV["TRACK"] || "production").to_s.strip
    UI.user_error!("TRACK must be 'beta' or 'production' (got: #{track.inspect})") \
      unless %w[beta production].include?(track)

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: false
    )

    version = _read_marketing_version

    UI.message("Submitting iOS build #{build_number} (v#{version}) to #{track}")

    if track == "production"
      # Submit the already-uploaded TestFlight build for App Store review.
      # `skip_binary_upload: true` + `build_number:` tells deliver to pick
      # the existing build instead of expecting a local IPA.
      # `automatic_release: false` so the human approves the actual release
      # to the App Store after Apple's review completes.
      deliver(
        api_key: api_key,
        build_number: build_number,
        app_version: version,
        skip_binary_upload: true,
        skip_screenshots: true,
        skip_metadata: true,
        submit_for_review: true,
        automatic_release: false,
        force: true,
        precheck_include_in_app_purchases: false,
        submission_information: {
          add_id_info_uses_idfa: false,
          export_compliance_uses_encryption: false
        }
      )
    else
      # Promote the TestFlight build to external testing groups, which
      # triggers Apple's beta review. The build must already be uploaded
      # by `deploy_testflight` for this to find it.
      pilot(
        api_key: api_key,
        build_number: build_number,
        app_version: version,
        skip_submission: false,
        skip_waiting_for_build_processing: true,
        distribute_external: true,
        groups: ENV.fetch("TESTFLIGHT_EXTERNAL_GROUPS", "External Beta").split(",").map(&:strip).reject(&:empty?),
        changelog: "Promoted build #{build_number} (v#{version}) to external beta"
      )
    end

    UI.success("Submitted iOS build #{build_number} (v#{version}) to #{track}")
  end

  desc "Build without uploading (for testing CI setup)"
  lane :build_only do
    setup_ci if ENV["CI"]

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: false
    )

    match(
      type: "appstore",
      api_key: api_key,
      readonly: true
    )

    app_identifier = CredentialsManager::AppfileConfig.try_fetch_value(:app_identifier)
    profile_name = ENV["sigh_#{app_identifier}_appstore_profile-name"]

    # Override automatic signing with match profile for CI
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Runner.xcodeproj",
      team_id: CredentialsManager::AppfileConfig.try_fetch_value(:team_id),
      bundle_identifier: app_identifier,
      profile_name: profile_name,
      code_sign_identity: "Apple Distribution"
    )

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      configuration: "Release",
      export_method: "app-store",
      skip_archive: false,
      output_directory: "./build"
    )

    UI.success("Build completed successfully!")
  end

  desc "Sync certificates and profiles without building"
  lane :sync_signing do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: false
    )

    match(
      type: "appstore",
      api_key: api_key,
      readonly: ENV["CI"] == "true"
    )

    UI.success("Code signing synced successfully!")
  end

  desc "Initialize Match repository (run once to create certificates)"
  lane :init_match do
    match(
      type: "appstore",
      readonly: false
    )

    UI.success("Match initialized! Certificates and profiles stored in git repository.")
  end
end
