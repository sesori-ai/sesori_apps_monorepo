# frozen_string_literal: true

require "base64"
require "fileutils"
require "shellwords"

# Resolves an optional store-metadata directory passed via the named env var.
# In CI this points at the private metadata repo that submit-release.yml clones
# into the workspace (see .github/workflows/submit-release.yml). Returns an
# ABSOLUTE path only when the directory exists and is non-empty; otherwise nil,
# so submit_android cleanly falls back to "promotion only" and behaves exactly
# as it did before this feature existed. Absolute because fastlane runs from
# mobile/app/android while the clone lives at the workspace root.
def metadata_dir_from_env(var)
  raw = ENV[var].to_s.strip
  return nil if raw.empty?

  path = File.expand_path(raw)
  return nil unless File.directory?(path)
  return nil if Dir.children(path).reject { |e| e.start_with?(".") }.empty?

  path
end

# Release notes for a TEST build (internal track): the message of the commit the
# build was created for, so testers/operators see exactly what changed. A short
# `commit: <sha>` trailer is appended so the originating commit is recoverable
# even if the matching `build-<N>` git tag is ever lost. Falls back to the SHA
# alone if git output is unavailable. `max_length` guards against store limits
# (Google Play release notes cap at 500 chars). NOTE: production "What's new" is
# NOT this — it's the fixed copy (default.txt) in the private metadata repo.
def build_commit_changelog(max_length: nil)
  sha = ENV.fetch("GITHUB_SHA") { `git rev-parse HEAD`.strip }
  message = `git log -1 --format=%B #{Shellwords.escape(sha)} 2>/dev/null`.strip
  message = `git log -1 --format=%B 2>/dev/null`.strip if message.empty?
  short_sha = sha[0, 7]
  text = message.empty? ? "commit: #{short_sha}" : "#{message}\n\ncommit: #{short_sha}"
  text = "#{text[0, max_length - 1].rstrip}…" if max_length && text.length > max_length
  text
end

default_platform(:android)

platform :android do
  # Materializes signing/credential files from environment variables so the
  # same lane works locally (where files are usually already on disk) and on
  # CI (where they're injected via secrets). Existing on-disk files are not
  # overwritten unless the corresponding env var is set.
  private_lane :_materialize_secret_files do
    android_root = File.expand_path("..", Dir.pwd) # mobile/app/android/

    keystore_b64 = ENV["ANDROID_KEYSTORE_BASE64"].to_s.strip
    unless keystore_b64.empty?
      keystore_path = File.join(android_root, "keystore", "release.keystore")
      FileUtils.mkdir_p(File.dirname(keystore_path))
      File.binwrite(keystore_path, Base64.decode64(keystore_b64))
      UI.message("Wrote release keystore to #{keystore_path}")
    end

    properties = ENV["ANDROID_PROPERTIES"].to_s
    unless properties.strip.empty?
      props_path = File.join(android_root, "release.properties")
      File.write(props_path, properties)
      UI.message("Wrote signing properties to #{props_path}")
    end

    service_account = ENV["GOOGLE_PLAY_SERVICE_ACCOUNT_JSON"].to_s
    unless service_account.strip.empty?
      sa_path = File.join(Dir.pwd, "service-account.json")
      File.write(sa_path, service_account)
      UI.message("Wrote Google Play service account to #{sa_path}")
    end
  end

  # Removes any files materialized by _materialize_secret_files. Only runs on
  # CI — locally these files are expected to persist between builds.
  private_lane :_cleanup_secret_files do
    unless ENV["CI"].to_s.strip.empty?
      android_root = File.expand_path("..", Dir.pwd)
      paths = [
        File.join(android_root, "keystore", "release.keystore"),
        File.join(android_root, "release.properties"),
        File.join(Dir.pwd, "service-account.json"),
      ]
      paths.each do |path|
        if File.exist?(path)
          FileUtils.rm_f(path)
          UI.message("Removed #{path}")
        end
      end
    end
  end

  private_lane :_get_all_version_codes do
    tracks = %w[internal alpha beta production]
    version_codes = []
    failures = {}

    tracks.each do |track|
      begin
        codes = google_play_track_version_codes(track: track)
        version_codes.concat(codes) if codes
      rescue StandardError => e
        # A track legitimately may have no releases yet (404 from the Play API).
        # Other failures (auth, network) must not be silently swallowed —
        # otherwise we'd compute a stale next version code.
        failures[track] = e
        UI.important("Could not read version codes from track '#{track}': #{e.message}")
      end
    end

    if failures.size == tracks.size
      details = failures.map { |t, e| "  - #{t}: #{e.class}: #{e.message}" }.join("\n")
      UI.user_error!(
        "Failed to read version codes from any Play track. " \
        "Refusing to fall back to 0 because that would collide with existing builds.\n#{details}"
      )
    end

    version_codes
  end

  # Resolves the marketing version (e.g. "1.0.6"). Prefers an injected
  # VERSION_NAME env so the submit workflow can run the LATEST Fastfile while
  # still stamping the version that matches the already-uploaded binary (the
  # submit job checks out the workflow's own ref, not the build's commit, so the
  # local pubspec may belong to a newer version — see submit-release.yml). Falls
  # back to reading pubspec.yaml two dirs up for build/standalone invocations.
  # The build-number suffix after `+` is intentionally ignored — Play decides
  # the version code, pubspec only owns the version name. Fails hard if the
  # version cannot be determined: defaulting would stamp a wrong version onto a
  # store release, which is worse than aborting.
  private_lane :_read_version_name do
    injected = ENV["VERSION_NAME"].to_s.strip
    if injected.empty?
      # Anchor to __dir__ (the fastlane folder) rather than Dir.pwd so the path
      # is correct regardless of the cwd fastlane resolves relative paths
      # against — matches the AAB path resolution below.
      pubspec_path = File.expand_path("../../pubspec.yaml", __dir__)
      pubspec_content = File.read(pubspec_path)
      version_match = pubspec_content.match(/version:\s*(\d+\.\d+\.\d+)/)
      UI.user_error!("Could not determine version name: VERSION_NAME is unset and no " \
                     "'version: X.Y.Z' was found in #{pubspec_path}") unless version_match
      version_match[1]
    else
      injected
    end
  end

  desc "Print the next Google Play version code without building or uploading"
  lane :next_version_code do
    version_codes = _get_all_version_codes
    new_build_number = (version_codes.compact.max || 0) + 1

    # Stable marker line parsed by CI. Keep the `NEXT_VERSION_CODE=<n>` format.
    UI.message("NEXT_VERSION_CODE=#{new_build_number}")
    new_build_number
  end

  # Runs `flutter build appbundle` from the Flutter project root (mobile/app/),
  # not from the fastlane folder. Output lands at
  # mobile/app/build/app/outputs/bundle/release/app-release.aab thanks to the
  # build dir redirect in mobile/app/android/build.gradle.kts.
  private_lane :_flutter_build_appbundle do |options|
    build_number = options[:build_number]
    flutter_root = File.expand_path(File.join("..", ".."), Dir.pwd)
    Dir.chdir(flutter_root) do
      sh "flutter build appbundle --release --build-number=#{build_number}"
    end
  end

  desc "Deploy a new build to Google Play Internal Testing track"
  lane :deploy_internal do
    # Stage any secrets that arrived as env vars (CI path). Locally this is a
    # no-op when the files already exist on disk.
    _materialize_secret_files

    begin
      # Prefer a version code injected by the upstream "next version code" CI step.
      # Fall back to querying Play ourselves so standalone invocations of this
      # lane still work.
      injected = ENV["VERSION_CODE"].to_s.strip
      new_build_number = if injected.empty?
        (_get_all_version_codes.compact.max || 0) + 1
      else
        UI.message("Using injected version code: #{injected}")
        Integer(injected)
      end

      version_name = _read_version_name
      UI.message("Building version #{version_name} (#{new_build_number})")

      # Build the AAB unless the caller pre-built one and pointed AAB_PATH at it.
      if ENV["AAB_PATH"].to_s.strip.empty?
        _flutter_build_appbundle(build_number: new_build_number)
      else
        UI.message("Skipping build, using pre-built AAB from AAB_PATH=#{ENV['AAB_PATH']}")
      end

      # Flutter outputs the AAB to `mobile/app/build/app/outputs/bundle/release/`
      # because the Android root build.gradle.kts redirects rootProject build
      # dir up two levels (standard Flutter pattern). Anchor to __dir__ (the
      # fastlane folder) so the absolute path is correct regardless of which
      # cwd fastlane actions resolve relative paths against.
      default_aab = File.expand_path(
        "../../build/app/outputs/bundle/release/app-release.aab", __dir__,
      )
      aab_path = ENV["AAB_PATH"].to_s.strip.empty? ? default_aab : File.expand_path(ENV["AAB_PATH"])

      unless File.exist?(aab_path)
        UI.user_error!("AAB not found at #{aab_path} after build.")
      end

      # Internal-track release notes = the build commit's message (with a
      # `commit: <sha>` trailer for recoverability if the matching `build-<N>`
      # git tag is ever lost). This is the TEST changelog only — production
      # "What's new" is the fixed copy (default.txt) in the private metadata
      # repo. Supply expects metadata_path to point directly at the directory
      # containing locale folders, i.e. `<metadata_path>/<lang>/changelogs/<versionCode>.txt`.
      metadata_path = File.expand_path("metadata/android", __dir__)
      changelog_dir = File.join(metadata_path, "en-US", "changelogs")
      FileUtils.mkdir_p(changelog_dir)
      File.write(
        File.join(changelog_dir, "#{new_build_number}.txt"),
        "#{build_commit_changelog(max_length: 500)}\n"
      )

      upload_to_play_store(
        track: "internal",
        aab: aab_path,
        metadata_path: metadata_path,
        skip_upload_metadata: true,
        skip_upload_images: true,
        skip_upload_screenshots: true,
        skip_upload_changelogs: false,
        release_status: "completed",
        version_name: version_name
      )

      # Write build info for CI summary
      File.write("../build_info.env", "VERSION=#{version_name}\nVERSION_CODE=#{new_build_number}\n")

      UI.success("Successfully uploaded version #{version_name} (#{new_build_number}) to Google Play Internal track!")
    ensure
      _cleanup_secret_files
    end
  end

  desc "Release an already-uploaded build (by version code) directly to beta " \
       "or production. Does NOT build — runs on Linux."
  lane :submit_android do |options|
    version_code = (options[:version_code] || ENV["VERSION_CODE"]).to_s.strip
    UI.user_error!("VERSION_CODE is required") if version_code.empty?

    track = (options[:track] || ENV["TRACK"] || "production").to_s.strip
    UI.user_error!("TRACK must be 'beta' or 'production' (got: #{track.inspect})") \
      unless %w[beta production].include?(track)

    _materialize_secret_files

    begin
      target_track = track == "beta" ? "beta" : "production"
      version_name = _read_version_name

      # Create a release for the requested version code DIRECTLY on the target
      # track, rather than promoting from internal.
      #
      # Why not `track_promote_to`? supply's promotion only operates on releases
      # that are still ACTIVE on the source ("internal") track. Google Play now
      # auto-supersedes/deactivates older releases when a newer build is added to
      # a track (the behaviour behind the now-deprecated `check_superseded_tracks`
      # and `deactivate_on_promote` options). So once a newer internal build (e.g.
      # 119) lands, an older-but-still-present build (e.g. 118) is no longer an
      # active release on internal and cannot be promoted — supply fails with
      # "Track 'internal' doesn't have any releases". Targeting the destination
      # track directly with the already-uploaded version code sidesteps this: the
      # uploaded AAB is permanent, so Play can create a fresh release referencing
      # it regardless of its status on internal.
      UI.message("Releasing Android version code #{version_code} (v#{version_name}) " \
                 "to #{target_track}")

      # Optional Play Store listing metadata from the private metadata repo. CI
      # populates this path only when that repo's latest commit has no `v*` tag
      # (unpublished listing changes — see submit-release.yml). Unlike iOS, supply
      # runs the release and the metadata upload inside a SINGLE Play Edit, so a
      # metadata error aborts the whole edit and the release does not half-land
      # — no two-pass split needed. nil when the path is unset, making this a
      # pure release (pre-feature behavior).
      metadata_dir = metadata_dir_from_env("ANDROID_METADATA_PATH")
      have_meta = !metadata_dir.nil?
      UI.message(
        have_meta ? "Uploading Play listing from #{metadata_dir}" : "No metadata path — release only"
      )

      # package_name comes from Appfile (matches deploy_internal).
      # `release_status: "completed"` implies 100% rollout — no `rollout:` needed.
      # `skip_upload_aab/apk: true` means we do NOT re-upload a binary; supply
      # creates the target-track release from the version code already uploaded by
      # deploy_internal.
      # When a metadata dir is present we upload everything in it (listing text,
      # changelogs, images, screenshots); supply no-ops on categories that have
      # no files, so a text-only repo just uploads text. Release notes come from
      # <metadata_dir>/<locale>/changelogs/<versionCode>.txt with a default.txt
      # fallback — keep a default.txt in the repo so a release never ships
      # blank "What's new" (supply does so silently).
      play_opts = {
        track: target_track,
        version_code: version_code.to_i,
        skip_upload_apk: true,
        skip_upload_aab: true,
        skip_upload_metadata: !have_meta,
        skip_upload_changelogs: !have_meta,
        skip_upload_images: !have_meta,
        skip_upload_screenshots: !have_meta,
        release_status: "completed"
      }
      play_opts[:metadata_path] = metadata_dir if metadata_dir
      upload_to_play_store(play_opts)

      UI.success("Released Android version code #{version_code} (v#{version_name}) " \
                 "to #{target_track}")
    ensure
      _cleanup_secret_files
    end
  end
end
