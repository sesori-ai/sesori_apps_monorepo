  "fixed_sql": [
    {
      "name": "projects_table",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"projects_table\" (\"project_id\" TEXT NOT NULL, \"path\" TEXT NOT NULL, \"hidden\" INTEGER NOT NULL DEFAULT 0 CHECK (\"hidden\" IN (0, 1)), \"base_branch\" TEXT NULL, \"worktree_counter\" INTEGER NOT NULL DEFAULT 0, \"display_name\" TEXT NULL, \"opened_at\" INTEGER NOT NULL, PRIMARY KEY (\"project_id\")) WITHOUT ROWID;"
        }
      ]
    },
    {
      "name": "sessions_table",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"sessions_table\" (\"session_id\" TEXT NOT NULL, \"project_id\" TEXT NOT NULL REFERENCES projects_table (project_id) ON DELETE CASCADE, \"worktree_path\" TEXT NULL, \"branch_name\" TEXT NULL, \"is_dedicated\" INTEGER NOT NULL CHECK (\"is_dedicated\" IN (0, 1)), \"archived_at\" INTEGER NULL, \"base_branch\" TEXT NULL, \"base_commit\" TEXT NULL, \"last_agent\" TEXT NULL, \"last_agent_model\" TEXT NULL, \"created_at\" INTEGER NOT NULL, \"last_activity_at\" INTEGER NULL, \"last_seen_at\" INTEGER NULL, \"last_user_message_at\" INTEGER NULL, \"plugin_id\" TEXT NOT NULL, \"title\" TEXT NULL, PRIMARY KEY (\"session_id\")) WITHOUT ROWID;"
        }
      ]
    },
    {
      "name": "deleted_sessions_table",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"deleted_sessions_table\" (\"session_id\" TEXT NOT NULL, \"plugin_id\" TEXT NOT NULL, \"deleted_at\" INTEGER NOT NULL, PRIMARY KEY (\"plugin_id\", \"session_id\")) WITHOUT ROWID;"
        }
      ]
    },
    {
      "name": "pull_requests_table",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"pull_requests_table\" (\"project_id\" TEXT NOT NULL REFERENCES projects_table (project_id) ON DELETE CASCADE, \"pr_number\" INTEGER NOT NULL, \"branch_name\" TEXT NOT NULL, \"url\" TEXT NOT NULL, \"title\" TEXT NOT NULL, \"state\" TEXT NOT NULL, \"mergeable_status\" TEXT NOT NULL, \"review_decision\" TEXT NOT NULL, \"check_status\" TEXT NOT NULL, \"last_checked_at\" INTEGER NOT NULL, \"created_at\" INTEGER NOT NULL, PRIMARY KEY (\"project_id\", \"pr_number\")) WITHOUT ROWID;"
        }
      ]
    }
